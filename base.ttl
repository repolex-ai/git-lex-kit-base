@prefix base: <https://repolex.ai/ontology/kit/base/> .
@prefix lex:  <https://repolex.ai/ontology/git-lex/lex/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# =============================================================================
# GIT-LEX BASE KIT
# =============================================================================
# The minimal default kit. Installed automatically by `git lex init` when no
# --kit is specified. Provides no domain-specific classes beyond what lex.ttl
# already declares (lex:Document). Specialized kits (squad, soul, canon, etc.)
# are installed alongside base, not instead of it.
#
# This kit exists so that every git-lex repo has a kit — eliminating the
# "no-kit" code path and all its special cases.
# =============================================================================

<https://repolex.ai/ontology/kit/base> a owl:Ontology ;
    rdfs:label "git-lex Base Kit" ;
    rdfs:comment "Minimal default kit. All repos have this." ;
    owl:versionInfo "0.1" .
