@prefix lex: <https://repolex.ai/ontology/git-lex/lex/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# GIT-LEX BUILT-IN ONTOLOGY (lex:)
# =============================================================================
# The universal vocabulary that ships with git-lex. Loaded into every repo
# regardless of which kit is in use. Provides:
#
#   1. The upper ontology — top-level type categories every kit subclasses
#      (Physical, Information, Process, Concept, Decision, etc.). Stable,
#      fixed, immutable across repos.
#
#   2. The git-lex tool vocabulary — extraction features (mentions, links),
#      provenance for quoted triples, identity properties.
#
#   3. Generic relationships and knowledge organization properties (relatedTo,
#      partOf, broader, narrower, etc.) that kit predicates can subPropertyOf
#      for cross-kit discoverability.
#
# Namespace: lex: = https://repolex.ai/ontology/git-lex/lex/
#
# Stack:
#   git:    — git objects (commits, blobs, refs)
#   lex:    — this file (universal built-in: types + tool features)
#   {kit}:  — domain-specific kit ontologies (squad, soul, canon, ...)
#   lex-o:  — per-repo open-world extensions (Canonizer-editable; lives in
#            assets/.lex/ontology/lex-o.ttl in extraction-heavy kits like canon)
#
# History note: this file used to be split between lex.ttl (extraction
# features) and lex-o.ttl (upper ontology). The two were merged because the
# distinction was always confusing — both shipped in the binary, both had the
# same stability contract — and freeing the lex-o: name made room for the
# real open-world extension layer that lives per-repo.
# =============================================================================

<https://repolex.ai/ontology/git-lex/lex> a owl:Ontology ;
    rdfs:label "git-lex Built-in Ontology" ;
    rdfs:comment "Universal built-in vocabulary for git-lex: upper ontology types, tool extraction features, generic relationships, and provenance properties. Loaded into every repo regardless of kit." ;
    owl:versionInfo "0.2" .


# =============================================================================
# UPPER ONTOLOGY — TOP-LEVEL CATEGORIES
# =============================================================================
# The broadest classification of things that can exist in a knowledge repo.
# Three branches: things that exist in space/time (Concrete), things that are
# thought (Abstract), things that are written down (Information).
#
# Every kit subclasses these so cross-kit SPARQL queries can find related
# entities regardless of which kit declared them. squad:Task subClassOf
# lex:Process and soul:Task subClassOf lex:Process, so a query over
# lex:Process finds both.
#
# This is the fixed skeleton. Don't add to it lightly — every kit depends
# on its stability.
# =============================================================================

lex:Thing a owl:Class ;
    rdfs:label "Thing" ;
    rdfs:comment "Root class for all entities in the knowledge graph." .

# --- Concrete: exists in space/time ---

lex:Concrete a owl:Class ;
    rdfs:subClassOf lex:Thing ;
    rdfs:label "Concrete" ;
    rdfs:comment "Things that exist in space and time: people, organizations, places, objects, events, processes." .

lex:Physical a owl:Class ;
    rdfs:subClassOf lex:Concrete ;
    rdfs:label "Physical" ;
    rdfs:comment "Tangible entities: people, organizations, tools, artifacts, places." .

lex:Event a owl:Class ;
    rdfs:subClassOf lex:Concrete ;
    rdfs:label "Event" ;
    rdfs:comment "Something that happens at a point or period in time: incidents, releases, meetings, battles." .

lex:Process a owl:Class ;
    rdfs:subClassOf lex:Concrete ;
    rdfs:label "Process" ;
    rdfs:comment "An ongoing activity or workflow: migrations, reviews, evolutions, tasks." .

# --- Abstract: doesn't exist in space/time ---

lex:Abstract a owl:Class ;
    rdfs:subClassOf lex:Thing ;
    rdfs:label "Abstract" ;
    rdfs:comment "Things that exist as ideas, not in physical space: concepts, patterns, qualities." .

lex:Concept a owl:Class ;
    rdfs:subClassOf lex:Abstract ;
    rdfs:label "Concept" ;
    rdfs:comment "An idea, principle, pattern, or technique: algorithms, architectures, theories, projects." .

lex:Quality a owl:Class ;
    rdfs:subClassOf lex:Abstract ;
    rdfs:label "Quality" ;
    rdfs:comment "A property or characteristic: complex, secure, deprecated, efficient." .

# --- Information: representations of knowledge ---

lex:Information a owl:Class ;
    rdfs:subClassOf lex:Thing ;
    rdfs:label "Information" ;
    rdfs:comment "Representations of knowledge: documents, decisions, observations." .

lex:Document a owl:Class ;
    rdfs:subClassOf lex:Information ;
    rdfs:label "Document" ;
    rdfs:comment "A content file in the repo. The primary unit of knowledge. Every .md file is a Document." .

lex:Decision a owl:Class ;
    rdfs:subClassOf lex:Information ;
    rdfs:label "Decision" ;
    rdfs:comment "A recorded choice with context and rationale. Answers 'why did we do this?'" .

lex:Reference a owl:Class ;
    rdfs:subClassOf lex:Information ;
    rdfs:label "Reference" ;
    rdfs:comment "A summary or pointer to external work: papers, articles, specifications." .

# Note: Observation as a class is replaced by RDF 1.2 quoted triples.
# Instead of creating Observation nodes, annotate triples directly:
#   << :elves lex:opposes :orcs >> lex:observedBy "agent-a@lex.local" .
# This is cleaner and every fact carries its own provenance.


# =============================================================================
# GENERIC RELATIONSHIPS
# =============================================================================
# Cross-kit relationship vocabulary. Kit-specific predicates should
# rdfs:subPropertyOf these for discoverability — a SPARQL query over
# lex:relatedTo finds every relationship in the graph regardless of kit.
# =============================================================================

lex:relatedTo a owl:ObjectProperty ;
    rdfs:label "related to" ;
    rdfs:comment "Generic relationship between entities. Kit-specific properties should rdfs:subPropertyOf this for discoverability." .

lex:supports a owl:ObjectProperty ;
    rdfs:subPropertyOf lex:relatedTo ;
    rdfs:label "supports" ;
    rdfs:comment "X supports, agrees with, is allied with, or enables Y." .

lex:opposes a owl:ObjectProperty ;
    rdfs:subPropertyOf lex:relatedTo ;
    rdfs:label "opposes" ;
    rdfs:comment "X opposes, conflicts with, or is against Y." .

lex:replaces a owl:ObjectProperty ;
    rdfs:subPropertyOf lex:relatedTo ;
    rdfs:label "replaces" ;
    rdfs:comment "X supersedes, replaces, or deprecates Y." .

lex:partOf a owl:ObjectProperty ;
    rdfs:subPropertyOf lex:relatedTo ;
    rdfs:label "part of" ;
    rdfs:comment "X is a component, member, or part of Y." .

lex:causes a owl:ObjectProperty ;
    rdfs:subPropertyOf lex:relatedTo ;
    rdfs:label "causes" ;
    rdfs:comment "X causes, triggers, or leads to Y." .

lex:requires a owl:ObjectProperty ;
    rdfs:subPropertyOf lex:relatedTo ;
    rdfs:label "requires" ;
    rdfs:comment "X depends on, requires, or needs Y." .


# =============================================================================
# KNOWLEDGE ORGANIZATION (inspired by SKOS)
# =============================================================================
# Hierarchical concept organization. Curation agents use these to build
# taxonomies as they discover patterns in the content.
# =============================================================================

lex:broader a owl:ObjectProperty ;
    rdfs:label "broader" ;
    rdfs:comment "X is a broader/more general concept than Y. Used for taxonomy building." .

lex:narrower a owl:ObjectProperty ;
    owl:inverseOf lex:broader ;
    rdfs:label "narrower" ;
    rdfs:comment "X is a narrower/more specific concept than Y. Inverse of broader." .


# =============================================================================
# IDENTITY AND DESCRIPTION
# =============================================================================
# Universal name/description/alias properties. Used across all kits.
# =============================================================================

lex:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "Human-readable name for an entity. Used across all kits." ;
    rdfs:range xsd:string .

lex:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:comment "A longer description or summary of what this entity is." ;
    rdfs:range xsd:string .

lex:alias a owl:DatatypeProperty ;
    rdfs:label "alias" ;
    rdfs:comment "Alternative name or synonym for this entity. An entity can have multiple aliases." ;
    rdfs:range xsd:string .


# =============================================================================
# EXTRACTION PROPERTIES (Tier 1 — pattern-matching, no LLM)
# =============================================================================
# Populated by built-in extractors that run during `git lex sync` on:
#   - document bodies (.md)
#   - commit messages
#   - git notes (if used)
#
# Extractors:
#   - wikilink extractor: [[reference]] → lex:linksTo
#   - @mention extractor: @agent → lex:mentions
#   - markdown link extractor: [text](url) → lex:linksTo / lex:externalLink
# =============================================================================

lex:mentions a owl:ObjectProperty ;
    rdfs:label "mentions" ;
    rdfs:comment "An @mention of an agent. Extracted from @agentname patterns in document bodies, commit messages, and git notes." .

lex:linksTo a owl:ObjectProperty ;
    rdfs:label "links to" ;
    rdfs:comment "An internal reference via [[wikilink]] or [text](path.md). Resolved to an IRI when the target file exists." .

lex:hasUnresolvedLink a owl:ObjectProperty ;
    rdfs:label "has unresolved link" ;
    rdfs:comment "Relates a subject to a blank node describing a reference that failed to resolve. Preserves the attempted predicate alongside the slug so audits can filter by the intended class (e.g. 'show me unresolved Agent references'). Paired with lex:unresolvedSlug and lex:unresolvedPredicate." .

lex:unresolvedSlug a owl:DatatypeProperty ;
    rdfs:label "unresolved slug" ;
    rdfs:comment "The literal string the author wrote as a reference that failed to resolve (e.g. '[[lspy]]' → 'lspy'). Paired with lex:unresolvedPredicate via blank node on lex:hasUnresolvedLink." ;
    rdfs:range xsd:string .

lex:unresolvedPredicate a owl:ObjectProperty ;
    rdfs:label "unresolved predicate" ;
    rdfs:comment "The ObjectProperty the author attempted to use when a reference failed to resolve (e.g. squad:from). Paired with lex:unresolvedSlug via blank node on lex:hasUnresolvedLink. Audit queries can chain through rdfs:range to determine the intended class." .

lex:externalLink a owl:DatatypeProperty ;
    rdfs:label "external link" ;
    rdfs:comment "A reference to an external URL via [text](https://...). Stored as the URL string." ;
    rdfs:range xsd:anyURI .


# =============================================================================
# GROUNDING — LINKING ENTITIES TO DOCUMENTS
# =============================================================================
# How entities connect to the documents they came from. Uses commit/blob
# references so knowledge survives document deletion.
# =============================================================================

lex:mentionedInPath a owl:DatatypeProperty ;
    rdfs:label "mentioned in path" ;
    rdfs:range xsd:string ;
    rdfs:comment "File path where this entity is mentioned. Joins with git:path in the filetree graph. Multiple values expected." .

lex:mentionedInBlob a owl:ObjectProperty ;
    rdfs:label "mentioned in blob" ;
    rdfs:comment "Content-addressed blob URI where this entity was extracted from. Joins with git:blob in the filetree graph. Used for stale detection — if the blob changes, the extraction needs refreshing." .

lex:sourceDocument a owl:DatatypeProperty ;
    rdfs:label "source document" ;
    rdfs:range xsd:string ;
    rdfs:comment "The primary file path this entity was extracted from. Unlike mentionedInPath (which can be many), sourceDocument identifies the canonical origin." .


# =============================================================================
# PROVENANCE — RDF 1.2 TRIPLE TERM ANNOTATIONS
# =============================================================================
# These properties annotate quoted triples directly via RDF 1.2.
# Instead of reification nodes, every fact carries its own provenance:
#
#   << :elves lex:opposes :orcs >> lex:observedBy "agent-a@lex.local" ;
#       lex:confidence 0.9 ;
#       lex:observedAt "2026-03-26T10:00:00Z"^^xsd:dateTime ;
#       lex:observedInCommit <commit/abc123> ;
#       lex:sourceDocument <commit/abc123/notes/middle-earth-factions.md> ;
#       lex:extractor "llm" ;
#       lex:filePath "notes/middle-earth-factions.md" ;
#       lex:blobHash "e7a2..." .
#
# This enables multi-agent knowledge: two agents can assert contradictory
# facts, and you can see who said what, when, with what confidence.
#
# Query example (SPARQL-star):
#   SELECT ?who ?conf WHERE {
#       << :elves lex:opposes :orcs >> lex:observedBy ?who ;
#           lex:confidence ?conf .
#   }
# =============================================================================

lex:observedBy a owl:DatatypeProperty ;
    rdfs:label "observed by" ;
    rdfs:comment "The agent (by git author email) that recorded this fact. Applied to quoted triples via RDF 1.2." ;
    rdfs:range xsd:string .

lex:observedAt a owl:DatatypeProperty ;
    rdfs:label "observed at" ;
    rdfs:comment "When this fact was recorded (ISO 8601 datetime). Applied to quoted triples via RDF 1.2." ;
    rdfs:range xsd:dateTime .

lex:observedInCommit a owl:ObjectProperty ;
    rdfs:label "observed in commit" ;
    rdfs:comment "The git commit where this fact was first recorded. Immutable provenance anchor. Applied to quoted triples via RDF 1.2." .

lex:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence" ;
    rdfs:comment "Agent's confidence in this fact, 0.0 to 1.0. Applied to quoted triples via RDF 1.2. Optional." ;
    rdfs:range xsd:decimal .

lex:extractor a owl:DatatypeProperty ;
    rdfs:label "extractor" ;
    rdfs:comment "Which extractor produced this triple: 'fm', 'wikilink', 'mention', 'llm', 'manual'." ;
    rdfs:range xsd:string .

lex:filePath a owl:DatatypeProperty ;
    rdfs:label "file path" ;
    rdfs:comment "Source file path this triple was extracted from." ;
    rdfs:range xsd:string .

lex:blobHash a owl:DatatypeProperty ;
    rdfs:label "blob hash" ;
    rdfs:comment "Git blob hash of the source file content when this triple was extracted." ;
    rdfs:range xsd:string .

lex:retracted a owl:DatatypeProperty ;
    rdfs:label "retracted" ;
    rdfs:comment "Whether this triple has been retracted (source file deleted). Applied to triple term annotations." ;
    rdfs:range xsd:boolean .
