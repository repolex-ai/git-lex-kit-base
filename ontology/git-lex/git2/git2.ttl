@prefix git2: <https://repolex.ai/ontology/git-lex/git2/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# GIT-LEX git2 ONTOLOGY (git2:)
# =============================================================================
# A faithful, verbatim mirror of the git2 (libgit2) Rust library's object model,
# for the git2 objects git-lex actually reads. Every class is a git2 type; every
# property is a git2 accessor, named as git2 names it. The domain of this
# vocabulary IS the git2 library — if git-lex ever modelled a different git
# library, that would be a different vocabulary.
#
# Namespace: git2: = https://repolex.ai/ontology/git-lex/git2/
# A parser namespace nested under the git-lex application.
#
# Library reference: git2 0.20 (crate binding to libgit2). Accessor names are
# cited in each comment. Where git2 reuses one accessor name across types with
# the SAME meaning (id, name), one property carries multiple rdfs:domain triples.
# Where the meaning differs by type, the property name is qualified so the
# vocabulary stays unambiguous.
# =============================================================================

<https://repolex.ai/ontology/git-lex/git2/> a owl:Ontology ;
    rdfs:label "git-lex git2 Ontology" ;
    rdfs:comment "A verbatim mirror of the git2 (libgit2) object model, for the git2 objects git-lex reads. Classes = git2 types, properties = git2 accessors." ;
    owl:versionInfo "0.1.0" .

# =============================================================================
# Classes (git2 type → git2: class)
# =============================================================================

git2:Repository a owl:Class ;
    rdfs:label "Repository" ;
    rdfs:comment "A git repository (git2::Repository)." .

git2:Commit a owl:Class ;
    rdfs:label "Commit" ;
    rdfs:comment "A git commit object (git2::Commit)." .

git2:Signature a owl:Class ;
    rdfs:label "Signature" ;
    rdfs:comment "A git action signature (git2::Signature): a name, an email, and a time. A value object attached per commit (as author and committer) and per blame hunk — not a deduplicated person." .

git2:Tree a owl:Class ;
    rdfs:label "Tree" ;
    rdfs:comment "A git tree object (git2::Tree): a directory listing of tree entries." .

git2:TreeEntry a owl:Class ;
    rdfs:label "TreeEntry" ;
    rdfs:comment "An entry in a tree (git2::TreeEntry): a name bound to an object id with a filemode. The path-in-tree pairing pointing at a Blob (or sub-Tree)." .

git2:Blob a owl:Class ;
    rdfs:label "Blob" ;
    rdfs:comment "A git blob object (git2::Blob): file content addressed by its id. No path — a blob is pure content, shared by every tree entry with identical bytes." .

git2:Reference a owl:Class ;
    rdfs:label "Reference" ;
    rdfs:comment "A git reference (git2::Reference): a named pointer to an object (branch or tag)." .

git2:Branch a owl:Class ;
    rdfs:subClassOf git2:Reference ;
    rdfs:label "Branch" ;
    rdfs:comment "A branch reference (git2::Branch)." .

git2:Tag a owl:Class ;
    rdfs:subClassOf git2:Reference ;
    rdfs:label "Tag" ;
    rdfs:comment "A tag reference (git2::Tag / a tag reference)." .

git2:DiffDelta a owl:Class ;
    rdfs:label "DiffDelta" ;
    rdfs:comment "A single file change within a diff (git2::DiffDelta): a status plus an old and new file side." .

git2:BlameHunk a owl:Class ;
    rdfs:label "BlameHunk" ;
    rdfs:comment "A contiguous run of lines attributed to one commit within a file's blame (git2::BlameHunk). Carries the original and final signatures for that hunk." .

# =============================================================================
# id — git2 `id()` returns an Oid on Commit, Tree, TreeEntry, Blob.
# One property, one meaning (the object's hex id), multiple domains.
# =============================================================================

git2:id a owl:DatatypeProperty ;
    rdfs:domain git2:Commit ;
    rdfs:domain git2:Tree ;
    rdfs:domain git2:TreeEntry ;
    rdfs:domain git2:Blob ;
    rdfs:range xsd:string ;
    rdfs:label "id" ;
    rdfs:comment "The object id (Oid) as a hex string (git2 `id()`). Present on Commit, Tree, TreeEntry, and Blob." .

# =============================================================================
# name — git2 `name()` on Signature, TreeEntry, Reference. Same accessor NAME,
# DIFFERENT meaning per type (a person's name vs a filename vs a ref name), so
# each is a distinct, qualified property rather than one overloaded `git2:name`.
# =============================================================================

git2:signatureName a owl:DatatypeProperty ;
    rdfs:domain git2:Signature ;
    rdfs:range xsd:string ;
    rdfs:label "signatureName" ;
    rdfs:comment "The signature's person name (git2 Signature `name()`)." .

git2:entryName a owl:DatatypeProperty ;
    rdfs:domain git2:TreeEntry ;
    rdfs:range xsd:string ;
    rdfs:label "entryName" ;
    rdfs:comment "The entry's filename — last path segment only (git2 TreeEntry `name()`)." .

git2:refName a owl:DatatypeProperty ;
    rdfs:domain git2:Reference ;
    rdfs:range xsd:string ;
    rdfs:label "refName" ;
    rdfs:comment "The reference's full name, e.g. refs/heads/main (git2 Reference `name()`)." .

# =============================================================================
# Commit properties (git2::Commit accessors)
# =============================================================================

git2:summary a owl:DatatypeProperty ;
    rdfs:domain git2:Commit ;
    rdfs:range xsd:string ;
    rdfs:label "summary" ;
    rdfs:comment "The commit message summary — first paragraph / subject line (git2 `summary()`)." .

git2:message a owl:DatatypeProperty ;
    rdfs:domain git2:Commit ;
    rdfs:range xsd:string ;
    rdfs:label "message" ;
    rdfs:comment "The full commit message (git2 `message()`)." .

git2:body a owl:DatatypeProperty ;
    rdfs:domain git2:Commit ;
    rdfs:range xsd:string ;
    rdfs:label "body" ;
    rdfs:comment "The commit message body — everything after the summary (git2 `body()`)." .

git2:author a owl:ObjectProperty ;
    rdfs:domain git2:Commit ;
    rdfs:range git2:Signature ;
    rdfs:label "author" ;
    rdfs:comment "The commit's author signature (git2 `author()`)." .

git2:committer a owl:ObjectProperty ;
    rdfs:domain git2:Commit ;
    rdfs:range git2:Signature ;
    rdfs:label "committer" ;
    rdfs:comment "The commit's committer signature (git2 `committer()`)." .

git2:parent a owl:ObjectProperty ;
    rdfs:domain git2:Commit ;
    rdfs:range git2:Commit ;
    rdfs:label "parent" ;
    rdfs:comment "A parent commit (git2 `parent_ids()`). A merge commit has more than one." .

git2:tree a owl:ObjectProperty ;
    rdfs:domain git2:Commit ;
    rdfs:range git2:Tree ;
    rdfs:label "tree" ;
    rdfs:comment "The tree this commit points at (git2 `tree()` / `tree_id()`)." .

# =============================================================================
# Signature properties (git2::Signature accessors) — name is git2:signatureName above
# =============================================================================

git2:email a owl:DatatypeProperty ;
    rdfs:domain git2:Signature ;
    rdfs:range xsd:string ;
    rdfs:label "email" ;
    rdfs:comment "The signature's email (git2 Signature `email()`)." .

git2:when a owl:DatatypeProperty ;
    rdfs:domain git2:Signature ;
    rdfs:range xsd:dateTime ;
    rdfs:label "when" ;
    rdfs:comment "The signature's time (git2 Signature `when()`). A commit's author-time and commit-time each live on their respective signature." .

# =============================================================================
# Tree / TreeEntry properties (git2::Tree, git2::TreeEntry accessors)
# entryName is above (the `name()` disambiguation).
# =============================================================================

git2:entry a owl:ObjectProperty ;
    rdfs:domain git2:Tree ;
    rdfs:range git2:TreeEntry ;
    rdfs:label "entry" ;
    rdfs:comment "An entry contained in this tree (git2 tree iteration)." .

git2:kind a owl:DatatypeProperty ;
    rdfs:domain git2:TreeEntry ;
    rdfs:range xsd:string ;
    rdfs:label "kind" ;
    rdfs:comment "The entry's object type (git2 TreeEntry `kind()` → ObjectType): one of blob, tree, commit, tag." .

git2:filemode a owl:DatatypeProperty ;
    rdfs:domain git2:TreeEntry ;
    rdfs:range xsd:integer ;
    rdfs:label "filemode" ;
    rdfs:comment "The entry's UNIX filemode (git2 TreeEntry `filemode()`)." .

git2:object a owl:ObjectProperty ;
    rdfs:domain git2:TreeEntry ;
    rdfs:range git2:Blob ;
    rdfs:label "object" ;
    rdfs:comment "The object this entry points at, by id (git2 TreeEntry `id()`) — a Blob (or a sub-Tree)." .

# =============================================================================
# Blob properties (git2::Blob accessors)
# =============================================================================

git2:size a owl:DatatypeProperty ;
    rdfs:domain git2:Blob ;
    rdfs:range xsd:integer ;
    rdfs:label "size" ;
    rdfs:comment "Blob content size in bytes (git2 Blob `size()`)." .

git2:isBinary a owl:DatatypeProperty ;
    rdfs:domain git2:Blob ;
    rdfs:range xsd:boolean ;
    rdfs:label "isBinary" ;
    rdfs:comment "Whether the blob content is binary (git2 Blob `is_binary()`)." .

# =============================================================================
# Reference properties (git2::Reference accessors) — refName is above
# =============================================================================

git2:shorthand a owl:DatatypeProperty ;
    rdfs:domain git2:Reference ;
    rdfs:range xsd:string ;
    rdfs:label "shorthand" ;
    rdfs:comment "The reference's human-readable short name (git2 Reference `shorthand()`)." .

git2:target a owl:ObjectProperty ;
    rdfs:domain git2:Reference ;
    rdfs:range git2:Commit ;
    rdfs:label "target" ;
    rdfs:comment "The object this reference points at, by id (git2 Reference `target()`)." .

# =============================================================================
# DiffDelta properties (git2::DiffDelta / DiffFile accessors)
# =============================================================================

git2:status a owl:DatatypeProperty ;
    rdfs:domain git2:DiffDelta ;
    rdfs:range xsd:string ;
    rdfs:label "status" ;
    rdfs:comment "The kind of change (git2 DiffDelta `status()` → Delta): one of unmodified, added, deleted, modified, renamed, copied, ignored, untracked, typechange, unreadable, conflicted." .

git2:oldPath a owl:DatatypeProperty ;
    rdfs:domain git2:DiffDelta ;
    rdfs:range xsd:string ;
    rdfs:label "oldPath" ;
    rdfs:comment "The old-side file path (git2 DiffDelta `old_file()` → DiffFile `path()`)." .

git2:newPath a owl:DatatypeProperty ;
    rdfs:domain git2:DiffDelta ;
    rdfs:range xsd:string ;
    rdfs:label "newPath" ;
    rdfs:comment "The new-side file path (git2 DiffDelta `new_file()` → DiffFile `path()`)." .

# =============================================================================
# BlameHunk properties (git2::BlameHunk accessors)
# =============================================================================

git2:origCommitId a owl:DatatypeProperty ;
    rdfs:domain git2:BlameHunk ;
    rdfs:range xsd:string ;
    rdfs:label "origCommitId" ;
    rdfs:comment "The original commit id for this hunk (git2 BlameHunk `orig_commit_id()`)." .

git2:finalCommitId a owl:DatatypeProperty ;
    rdfs:domain git2:BlameHunk ;
    rdfs:range xsd:string ;
    rdfs:label "finalCommitId" ;
    rdfs:comment "The final commit id for this hunk (git2 BlameHunk `final_commit_id()`)." .

git2:origSignature a owl:ObjectProperty ;
    rdfs:domain git2:BlameHunk ;
    rdfs:range git2:Signature ;
    rdfs:label "origSignature" ;
    rdfs:comment "The original signature for this hunk (git2 BlameHunk `orig_signature()`)." .

git2:finalSignature a owl:ObjectProperty ;
    rdfs:domain git2:BlameHunk ;
    rdfs:range git2:Signature ;
    rdfs:label "finalSignature" ;
    rdfs:comment "The final signature for this hunk (git2 BlameHunk `final_signature()`)." .

git2:origStartLine a owl:DatatypeProperty ;
    rdfs:domain git2:BlameHunk ;
    rdfs:range xsd:integer ;
    rdfs:label "origStartLine" ;
    rdfs:comment "The 1-based line where this hunk begins in the original file (git2 BlameHunk `orig_start_line()`)." .

git2:finalStartLine a owl:DatatypeProperty ;
    rdfs:domain git2:BlameHunk ;
    rdfs:range xsd:integer ;
    rdfs:label "finalStartLine" ;
    rdfs:comment "The 1-based line where this hunk begins in the final file (git2 BlameHunk `final_start_line()`)." .

git2:linesInHunk a owl:DatatypeProperty ;
    rdfs:domain git2:BlameHunk ;
    rdfs:range xsd:integer ;
    rdfs:label "linesInHunk" ;
    rdfs:comment "The number of lines in this hunk (git2 BlameHunk `lines_in_hunk()`)." .

git2:hunkPath a owl:DatatypeProperty ;
    rdfs:domain git2:BlameHunk ;
    rdfs:range xsd:string ;
    rdfs:label "hunkPath" ;
    rdfs:comment "The file path this blame hunk belongs to (git2 BlameHunk `path()`)." .
